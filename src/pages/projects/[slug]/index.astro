---
import '../../../styles/global.css'
import HomeLayout from '../../../layouts/HomeLayout.astro';
import { PROJECTS_DATA } from '../../../data/project-details.js';
import ProjectDetailsPage from '../../../components/Projects/ProjectDetails/ProjectDetailsPage.jsx';

export async function getStaticPaths() {
  return PROJECTS_DATA.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const siteUrl = "https://tcjrealty.in";
const ogImageUrl = `${siteUrl}${project.image}`;
---

<HomeLayout 
  title={`${project.projectName} | TCJ Realty`}
  ogImage={ogImageUrl}
  description={`${project.overview.description}`}
>
  <ProjectDetailsPage client:load project={project} />
</HomeLayout>