---
import '../styles/global.css';
import HomeLayout from '../layouts/HomeLayout.astro';
import { motion } from "framer-motion";
import { ArrowLeft, Home } from "lucide-react";
---

<HomeLayout title="404 - Page Not Found | TCJ Realty">
  <section class="relative min-h-[90vh] flex items-center justify-center bg-white overflow-hidden">
    
    {/* Subtle Background Watermark */}
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
      <h1 class="font-heading text-[25vw] text-slate-50 opacity-[0.03] leading-none">404</h1>
    </div>

    <div class="relative z-10 text-center px-6 max-w-2xl mx-auto">
      <div class="mb-8">
        <span class="font-body text-accent text-xs tracking-[0.5em] font-bold uppercase">
          Error Information
        </span>
      </div>

      <h2 class="font-heading text-primary-bg text-5xl md:text-6xl mb-6 leading-tight">
        The path you seek is <br />
        <span class="italic font-normal text-accent">Not Available.</span>
      </h2>

      <p class="font-body text-slate-500 text-sm md:text-base leading-relaxed mb-12 max-w-md mx-auto">
        The page you are looking for might have been removed, had its name changed, or is temporarily unavailable. Let us guide you back to our elite developments.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        {/* Back Button */}
        <button 
          onclick="history.back()"
          class="flex items-center gap-3 font-body text-[10px] tracking-[0.3em] font-bold uppercase text-primary-bg hover:text-accent transition-colors group"
        >
          <ArrowLeft size={16} class="group-hover:-translate-x-1 transition-transform" />
          Go Back
        </button>

        <div class="hidden sm:block w-px h-8 bg-slate-200"></div>

        {/* Home Link */}
        <a 
          href="/" 
          class="bg-primary-bg text-white px-10 py-4 font-body text-[10px] tracking-[0.3em] font-bold uppercase hover:bg-accent transition-all duration-300 flex items-center gap-3"
        >
          <Home size={14} />
          Return Home
        </a>
      </div>

      {/* Luxury Detail: Animated Divider */}
      <div class="mt-20 w-16 h-px bg-accent mx-auto relative overflow-hidden">
        <div class="absolute inset-0 bg-white -translate-x-full animate-shimmer"></div>
      </div>
    </div>
  </section>
</HomeLayout>

<style>
  @keyframes shimmer {
    100% { transform: translateX(100%); }
  }
  .animate-shimmer {
    animation: shimmer 4s infinite linear;
  }
</style>