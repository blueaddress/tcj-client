---
import '../styles/global.css';
import HomeLayout from '../layouts/HomeLayout.astro';
import ZoomWrapper from '../components/Shared/ZoomWrapper.jsx';
import Hero from '../components/HomePage/Hero.jsx';
import About from '../components/HomePage/About.jsx';
import CurrentDevelopments from '../components/HomePage/CurentDevelopments.jsx';
import Stats from '../components/HomePage/Stats.jsx';
import EnquireNow from "../components/HomePage/EnquireNow.jsx";
import Footer from "../components/Shared/Footer.jsx";

---
<HomeLayout 
	title="TCJ Realty | Real Estate Developer" 
	structuredData={{
		"@context": "https://schema.org",
		"@type": "Organization",
		"name": "TCJ Realty",
		"description":"Established  in 1996, TCJ Realty is one of the most distinguished and admired real estate developers in Kalyan, Ambernath & Badlapur",
		"url": "https://www.tcjrealty.in",
		"logo": "https://www.tcjrealty.in/images/tcj-logo.jpg",
		"sameAs": [
		"https://www.facebook.com/share/18zPs5EjkZ/?mibextid=wwXIfr",
		"https://www.linkedin.com/company/tcjrealty/",
		"https://www.instagram.com/tcj.realty/",
		"https://x.com/tcjrealty"
		],
		"foundingDate": "1996-05-01"
	}}
>
	<ZoomWrapper client:load>
		<Hero client:load/>
		<About client:visible/>
		<CurrentDevelopments client:visible/>
		<Stats client:visible/>
		<EnquireNow client:visible/>
		<Footer client:visible/>
	</ZoomWrapper>
</HomeLayout>
